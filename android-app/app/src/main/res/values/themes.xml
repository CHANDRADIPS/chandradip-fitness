<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.ChandradipFitness" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand colors. -->
        <item name="colorPrimary">@color/gold</item>
        <item name="colorPrimaryVariant">@color/saffron</item>
        <item name="colorOnPrimary">@color/pitch_black</item>
        <!-- Secondary brand colors. -->
        <item name="colorSecondary">@color/saffron</item>
        <item name="colorSecondaryVariant">@color/gold</item>
        <item name="colorOnSecondary">@color/pitch_black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor" tools:targetApi="l">@color/pitch_black</item>
        <!-- Background colors -->
        <item name="android:windowBackground">@color/pitch_black</item>
    </style>
</resources>
